# ── REQUIRED ───────────────────────────────────────────────────────
# Groq (free): https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Ticketmaster (free): https://developer.ticketmaster.com
TICKETMASTER_API_KEY=your_ticketmaster_key_here

# ── OPTIONAL ───────────────────────────────────────────────────────
# OpenSky (higher rate limits with account): opensky-network.org
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── SETTINGS ───────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
DB_PATH=data/pricing.db
